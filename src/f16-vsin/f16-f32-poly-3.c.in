$assert FUN in {"SIN", "COS"}
$BATCH_TILES = tuple(int(bt) for bt in BATCH_TILES.split(","))
$SIMD_SIZE = {
$  "scalar": 1,
$  "neon": 4,
$  "neonfp16": 4,
$  "wasmrelaxedsimd": 4,
$  "f16c": 8,
$  "avx512f": 16,
$  "hvx": 32,
$}[ARCH]
#include <assert.h>
#include <stddef.h>
#include <stdint.h>

#include "src/xnnpack/common.h"
#include "src/xnnpack/math.h"
#include "src/xnnpack/microparams.h"

$SIMD_ARCH = {
$  "f16c": "avx",
$  "neonfp16": "neon",
$}.get(ARCH, ARCH)
#include "src/xnnpack/simd/f32-${SIMD_ARCH}.h"

$if ARCH == "wasmrelaxedsimd":
  #undef XNN_SIMD_HAS_NATIVE_FMA
  #include "src/xnnpack/simd/f16-wasmrelaxedsimd.h"
$elif ARCH == "scalar":
  #include "src/xnnpack/simd/f16-scalar.h"
$elif ARCH not in ("f16c", "avx512f", "neon", "neonfp16", "hvx"):
  #include "src/xnnpack/simd/f16-scalar.h"

#include "src/xnnpack/vunary.h"

// Helper functions for f16 <-> f32 conversion using xnn_simd_f32_t.
static XNN_INLINE xnn_simd_f32_t xnn_loadu_f16_f32(const xnn_float16* ptr) {
  return xnn_cvt_f32_f16(xnn_loadu_f16(ptr));
}

static XNN_INLINE void xnn_store_f32_f16(xnn_float16* ptr, xnn_simd_f32_t v) {
  xnn_store_tail_f16(ptr, xnn_cvt_f16_f32(v), xnn_simd_size_f32);
}

static XNN_INLINE xnn_simd_f32_t xnn_load_f16_f32(const xnn_float16* ptr, size_t elements) {
  return xnn_cvt_f32_f16(xnn_load_tail_f16(ptr, elements));
}

static XNN_INLINE void xnn_store_f32_f16_tail(xnn_float16* ptr, xnn_simd_f32_t v, size_t elements) {
  xnn_store_tail_f16(ptr, xnn_cvt_f16_f32(v), elements);
}

$for BATCH_TILE in BATCH_TILES:
  $assert BATCH_TILE % SIMD_SIZE == 0
  $assert BATCH_TILE >= SIMD_SIZE
  $SIMD_TILE = BATCH_TILE // SIMD_SIZE

  void xnn_f16_f32acc_v${FUN.lower()}_ukernel__${ARCH}_poly_3_u${BATCH_TILE}(
      size_t batch,
      const xnn_float16* input,
      xnn_float16* output,
      const struct xnn_f16_default_params* unused_params)
  {
    assert(batch != 0);
    assert(batch % sizeof(xnn_float16) == 0);
    assert(input != NULL);
    assert(output != NULL);
    assert(xnn_simd_size_f32 == ${SIMD_SIZE});

    XNN_SIMD_CONST_F32(vmagic, 12582912.0f);  // 1.5 * 2^23
    $if FUN == "SIN":
      XNN_SIMD_CONST_F32(vone_over_pi, 0.31830988618379067154f);
      #if XNN_SIMD_HAS_NATIVE_FMA
        XNN_SIMD_CONST_F32(vpi_0, -3.14159274e+00f);
        XNN_SIMD_CONST_F32(vpi_1, 8.74227766e-08f);
        XNN_SIMD_CONST_F32(vpi_2, 3.43024902e-15f);
      #else
        XNN_SIMD_CONST_F32(vpi_0, -3.14062500e+00f);
        XNN_SIMD_CONST_F32(vpi_1, -9.67502594e-04f);
        XNN_SIMD_CONST_F32(vpi_2, -1.50990672e-07f);
        XNN_SIMD_CONST_F32(vpi_3, -5.12656584e-12f);
        XNN_SIMD_CONST_F32(vpi_4, -1.22514845e-16f);
      #endif
    $else:
      XNN_SIMD_CONST_F32(vtwo_over_pi, 0.63661977236758134308f);
      XNN_SIMD_CONST_F32(vpi_over_two, 1.5707963267948966f);
      XNN_SIMD_CONST_F32(vone, 1.0f);
      #if XNN_SIMD_HAS_NATIVE_FMA
        XNN_SIMD_CONST_F32(vhalf_pi_0, -1.57079637e+00f);
        XNN_SIMD_CONST_F32(vhalf_pi_1, 4.37113883e-08f);
        XNN_SIMD_CONST_F32(vhalf_pi_2, 1.71512451e-15f);
      #else
        XNN_SIMD_CONST_F32(vhalf_pi_0, -1.57031250e+00f);
        XNN_SIMD_CONST_F32(vhalf_pi_1, -4.83751297e-04f);
        XNN_SIMD_CONST_F32(vhalf_pi_2, -7.54953362e-08f);
        XNN_SIMD_CONST_F32(vhalf_pi_3, -2.56328292e-12f);
        XNN_SIMD_CONST_F32(vhalf_pi_4, -6.12574227e-17f);
      #endif

    // Monomial coefficients for sin(x)/x on [-pi/2, pi/2]
    XNN_SIMD_CONST_F32(vc3, -1.9884618814e-04f);
    XNN_SIMD_CONST_F32(vc2, 8.3336085081e-03f);
    XNN_SIMD_CONST_F32(vc1, -1.6666665673e-01f);
    XNN_SIMD_CONST_F32(vc0, 1.0000000000e+00f);

    $if SIMD_TILE > 1:
      for (; batch >= ${BATCH_TILE} * sizeof(xnn_float16); batch -= ${BATCH_TILE} * sizeof(xnn_float16)) {
        $for N in range(SIMD_TILE):
          xnn_simd_f32_t vx_${N} = xnn_loadu_f16_f32(input + ${N} * ${SIMD_SIZE});
        input += ${BATCH_TILE};

        $if FUN == "SIN":
          $for N in range(SIMD_TILE):
            xnn_simd_f32_t vy_${N} = xnn_mul_f32(vx_${N}, vone_over_pi);

          $for N in range(SIMD_TILE):
            xnn_simd_f32_t vk_${N} = xnn_add_f32(vy_${N}, vmagic);

          $for N in range(SIMD_TILE):
            xnn_simd_f32_t vk_float_${N} = xnn_sub_f32(vk_${N}, vmagic);

          #if XNN_SIMD_HAS_NATIVE_FMA
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vpi_0, vx_${N});
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vpi_1, vx_${N});
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vpi_2, vx_${N});
          #else
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vpi_0, vx_${N});
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vpi_1, vx_${N});
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vpi_2, vx_${N});
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vpi_3, vx_${N});
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vpi_4, vx_${N});
          #endif

          $for N in range(SIMD_TILE):
            xnn_simd_f32_t vsign_flip_${N} = xnn_sll_f32(vk_${N}, 31);
          $for N in range(SIMD_TILE):
            vx_${N} = xnn_xor_f32(vx_${N}, vsign_flip_${N});
        $else:
          $for N in range(SIMD_TILE):
            xnn_simd_f32_t vy_${N} = xnn_mul_f32(vx_${N}, vtwo_over_pi);

          $for N in range(SIMD_TILE):
            xnn_simd_f32_t vk_${N} = xnn_add_f32(vy_${N}, vmagic);

          $for N in range(SIMD_TILE):
            xnn_simd_f32_t vk_float_${N} = xnn_sub_f32(vk_${N}, vmagic);

          #if XNN_SIMD_HAS_NATIVE_FMA
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vhalf_pi_0, vx_${N});
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vhalf_pi_1, vx_${N});
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vhalf_pi_2, vx_${N});
          #else
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vhalf_pi_0, vx_${N});
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vhalf_pi_1, vx_${N});
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vhalf_pi_2, vx_${N});
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vhalf_pi_3, vx_${N});
            $for N in range(SIMD_TILE):
              vx_${N} = xnn_fmadd_f32(vk_float_${N}, vhalf_pi_4, vx_${N});
          #endif

          $for N in range(SIMD_TILE):
            xnn_simd_f32_t vk_quad_${N} = xnn_add_f32(vk_${N}, vone);

          $for N in range(SIMD_TILE):
            xnn_simd_f32_t vmask_odd_${N} = xnn_sra_f32(xnn_sll_f32(vk_quad_${N}, 31), 31);
          $for N in range(SIMD_TILE):
            xnn_simd_f32_t vsign_flip_${N} = xnn_sll_f32(xnn_srl_f32(vk_quad_${N}, 1), 31);

          $for N in range(SIMD_TILE):
            xnn_simd_f32_t vabs_x_${N} = xnn_abs_f32(vx_${N});
          $for N in range(SIMD_TILE):
            xnn_simd_f32_t vsub_x_${N} = xnn_sub_f32(vpi_over_two, vabs_x_${N});
          $for N in range(SIMD_TILE):
            vx_${N} = xnn_or_f32(xnn_and_f32(vmask_odd_${N}, vsub_x_${N}), xnn_andnot_f32(vmask_odd_${N}, vx_${N}));
          $for N in range(SIMD_TILE):
            vx_${N} = xnn_xor_f32(vx_${N}, vsign_flip_${N});

        $for N in range(SIMD_TILE):
          const xnn_simd_f32_t vx2_${N} = xnn_mul_f32(vx_${N}, vx_${N});

        $for N in range(SIMD_TILE):
          xnn_simd_f32_t vp_${N} = xnn_fmadd_f32(vx2_${N}, vc3, vc2);
        $for N in range(SIMD_TILE):
          vp_${N} = xnn_fmadd_f32(vx2_${N}, vp_${N}, vc1);
        $for N in range(SIMD_TILE):
          vp_${N} = xnn_fmadd_f32(vx2_${N}, vp_${N}, vc0);

        $for N in range(SIMD_TILE):
          const xnn_simd_f32_t vy_res_${N} = xnn_mul_f32(vx_${N}, vp_${N});

        $for N in range(SIMD_TILE):
          xnn_store_f32_f16(output + ${N} * ${SIMD_SIZE}, vy_res_${N});
        output += ${BATCH_TILE};
      }

    for (; batch >= ${SIMD_SIZE} * sizeof(xnn_float16); batch -= ${SIMD_SIZE} * sizeof(xnn_float16)) {
      xnn_simd_f32_t vx = xnn_loadu_f16_f32(input);
      input += ${SIMD_SIZE};

      $if FUN == "SIN":
        xnn_simd_f32_t vy = xnn_mul_f32(vx, vone_over_pi);
        xnn_simd_f32_t vk = xnn_add_f32(vy, vmagic);
        xnn_simd_f32_t vk_float = xnn_sub_f32(vk, vmagic);

        #if XNN_SIMD_HAS_NATIVE_FMA
          vx = xnn_fmadd_f32(vk_float, vpi_0, vx);
          vx = xnn_fmadd_f32(vk_float, vpi_1, vx);
          vx = xnn_fmadd_f32(vk_float, vpi_2, vx);
        #else
          vx = xnn_fmadd_f32(vk_float, vpi_0, vx);
          vx = xnn_fmadd_f32(vk_float, vpi_1, vx);
          vx = xnn_fmadd_f32(vk_float, vpi_2, vx);
          vx = xnn_fmadd_f32(vk_float, vpi_3, vx);
          vx = xnn_fmadd_f32(vk_float, vpi_4, vx);
        #endif

        xnn_simd_f32_t vsign_flip = xnn_sll_f32(vk, 31);
        vx = xnn_xor_f32(vx, vsign_flip);
      $else:
        xnn_simd_f32_t vy = xnn_mul_f32(vx, vtwo_over_pi);
        xnn_simd_f32_t vk = xnn_add_f32(vy, vmagic);
        xnn_simd_f32_t vk_float = xnn_sub_f32(vk, vmagic);

        #if XNN_SIMD_HAS_NATIVE_FMA
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_0, vx);
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_1, vx);
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_2, vx);
        #else
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_0, vx);
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_1, vx);
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_2, vx);
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_3, vx);
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_4, vx);
        #endif

        xnn_simd_f32_t vk_quad = xnn_add_f32(vk, vone);

        xnn_simd_f32_t vmask_odd = xnn_sra_f32(xnn_sll_f32(vk_quad, 31), 31);
        xnn_simd_f32_t vsign_flip = xnn_sll_f32(xnn_srl_f32(vk_quad, 1), 31);

        xnn_simd_f32_t vabs_x = xnn_abs_f32(vx);
        xnn_simd_f32_t vsub_x = xnn_sub_f32(vpi_over_two, vabs_x);
        vx = xnn_or_f32(xnn_and_f32(vmask_odd, vsub_x), xnn_andnot_f32(vmask_odd, vx));
        vx = xnn_xor_f32(vx, vsign_flip);

      const xnn_simd_f32_t vx2 = xnn_mul_f32(vx, vx);
      xnn_simd_f32_t vp = xnn_fmadd_f32(vx2, vc3, vc2);
      vp = xnn_fmadd_f32(vx2, vp, vc1);
      vp = xnn_fmadd_f32(vx2, vp, vc0);

      const xnn_simd_f32_t vy_res = xnn_mul_f32(vx, vp);
      xnn_store_f32_f16(output, vy_res);
      output += ${SIMD_SIZE};
    }

    if XNN_UNLIKELY(batch != 0) {
      xnn_simd_f32_t vx = xnn_load_f16_f32(input, batch >> XNN_LOG2_SIZEOF_FLOAT16);

      $if FUN == "SIN":
        xnn_simd_f32_t vy = xnn_mul_f32(vx, vone_over_pi);
        xnn_simd_f32_t vk = xnn_add_f32(vy, vmagic);
        xnn_simd_f32_t vk_float = xnn_sub_f32(vk, vmagic);

        #if XNN_SIMD_HAS_NATIVE_FMA
          vx = xnn_fmadd_f32(vk_float, vpi_0, vx);
          vx = xnn_fmadd_f32(vk_float, vpi_1, vx);
          vx = xnn_fmadd_f32(vk_float, vpi_2, vx);
        #else
          vx = xnn_fmadd_f32(vk_float, vpi_0, vx);
          vx = xnn_fmadd_f32(vk_float, vpi_1, vx);
          vx = xnn_fmadd_f32(vk_float, vpi_2, vx);
          vx = xnn_fmadd_f32(vk_float, vpi_3, vx);
          vx = xnn_fmadd_f32(vk_float, vpi_4, vx);
        #endif

        xnn_simd_f32_t vsign_flip = xnn_sll_f32(vk, 31);
        vx = xnn_xor_f32(vx, vsign_flip);
      $else:
        xnn_simd_f32_t vy = xnn_mul_f32(vx, vtwo_over_pi);
        xnn_simd_f32_t vk = xnn_add_f32(vy, vmagic);
        xnn_simd_f32_t vk_float = xnn_sub_f32(vk, vmagic);

        #if XNN_SIMD_HAS_NATIVE_FMA
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_0, vx);
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_1, vx);
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_2, vx);
        #else
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_0, vx);
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_1, vx);
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_2, vx);
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_3, vx);
          vx = xnn_fmadd_f32(vk_float, vhalf_pi_4, vx);
        #endif

        xnn_simd_f32_t vk_quad = xnn_add_f32(vk, vone);

        xnn_simd_f32_t vmask_odd = xnn_sra_f32(xnn_sll_f32(vk_quad, 31), 31);
        xnn_simd_f32_t vsign_flip = xnn_sll_f32(xnn_srl_f32(vk_quad, 1), 31);

        xnn_simd_f32_t vabs_x = xnn_abs_f32(vx);
        xnn_simd_f32_t vsub_x = xnn_sub_f32(vpi_over_two, vabs_x);
        vx = xnn_or_f32(xnn_and_f32(vmask_odd, vsub_x), xnn_andnot_f32(vmask_odd, vx));
        vx = xnn_xor_f32(vx, vsign_flip);

      const xnn_simd_f32_t vx2 = xnn_mul_f32(vx, vx);
      xnn_simd_f32_t vp = xnn_fmadd_f32(vx2, vc3, vc2);
      vp = xnn_fmadd_f32(vx2, vp, vc1);
      vp = xnn_fmadd_f32(vx2, vp, vc0);

      const xnn_simd_f32_t vy_res = xnn_mul_f32(vx, vp);
      xnn_store_f32_f16_tail(output, vy_res, batch >> XNN_LOG2_SIZEOF_FLOAT16);
    }
  }
