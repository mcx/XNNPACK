$assert FUN in {"SIN", "COS"}
$BATCH_TILES = tuple(int(bt) for bt in BATCH_TILES.split(","))
$SIMD_SIZE = BATCH_TILES[0]
#include <assert.h>
#include <stddef.h>
#include <stdint.h>

#include "src/xnnpack/common.h"
#include "src/xnnpack/math.h"
#include "src/xnnpack/microparams.h"
#include "src/xnnpack/simd/f16-${ARCH}.h"
#include "src/xnnpack/vunary.h"

$for BATCH_TILE in BATCH_TILES:
  $assert BATCH_TILE % SIMD_SIZE == 0
  $assert BATCH_TILE >= SIMD_SIZE
  $SIMD_TILE = BATCH_TILE // SIMD_SIZE

  void xnn_f16_v${FUN.lower()}_ukernel__${ARCH}_poly_3_u${BATCH_TILE}(
      size_t batch,
      const xnn_float16* input,
      xnn_float16* output,
      const struct xnn_f16_default_params* unused_params)
  {
    assert(batch != 0);
    assert(batch % sizeof(xnn_float16) == 0);
    assert(input != NULL);
    assert(output != NULL);
    assert(xnn_simd_size_f16 == ${SIMD_SIZE});

    XNN_SIMD_CONST_F16_FROM_FLOAT(vmagic, 1536.0f);  // 1.5 * 2^10
    $if FUN == "SIN":
      XNN_SIMD_CONST_F16_FROM_FLOAT(vone_over_pi, 0.318359375f);
      XNN_SIMD_CONST_F16_FROM_FLOAT(vpi_0, -3.140625f);
      XNN_SIMD_CONST_F16_FROM_FLOAT(vpi_1, -9.675026e-4f);
    $else:
      XNN_SIMD_CONST_F16_FROM_FLOAT(vtwo_over_pi, 0.63671875f);
      XNN_SIMD_CONST_F16_FROM_FLOAT(vpi_over_two, 1.5703125f);
      XNN_SIMD_CONST_F16_FROM_FLOAT(vone, 1.0f);
      XNN_SIMD_CONST_F16_FROM_FLOAT(vhalf_pi_0, -1.5703125f);
      XNN_SIMD_CONST_F16_FROM_FLOAT(vhalf_pi_1, -4.837513e-4f);

    // Monomial coefficients for sin(x)/x on [-pi/2, pi/2]
    XNN_SIMD_CONST_F16_FROM_FLOAT(vc3, -1.98846e-4f);
    XNN_SIMD_CONST_F16_FROM_FLOAT(vc2, 8.3336e-3f);
    XNN_SIMD_CONST_F16_FROM_FLOAT(vc1, -1.666666e-1f);
    XNN_SIMD_CONST_F16_FROM_FLOAT(vc0, 1.0f);

    $if SIMD_TILE > 1:
      for (; batch >= ${BATCH_TILE} * sizeof(xnn_float16); batch -= ${BATCH_TILE} * sizeof(xnn_float16)) {
        $for N in range(SIMD_TILE):
          xnn_simd_f16_t vx_${N} = xnn_loadu_f16(input + ${N} * xnn_simd_size_f16);
        input += ${BATCH_TILE};

        $if FUN == "SIN":
          $for N in range(SIMD_TILE):
            xnn_simd_f16_t vy_${N} = xnn_mul_f16(vx_${N}, vone_over_pi);

          $for N in range(SIMD_TILE):
            xnn_simd_f16_t vk_${N} = xnn_add_f16(vy_${N}, vmagic);

          $for N in range(SIMD_TILE):
            xnn_simd_f16_t vk_float_${N} = xnn_sub_f16(vk_${N}, vmagic);

          $for N in range(SIMD_TILE):
            vx_${N} = xnn_fmadd_f16(vk_float_${N}, vpi_0, vx_${N});
          $for N in range(SIMD_TILE):
            vx_${N} = xnn_fmadd_f16(vk_float_${N}, vpi_1, vx_${N});

          $for N in range(SIMD_TILE):
            xnn_simd_f16_t vsign_flip_${N} = xnn_sll_f16(vk_${N}, 15);
          $for N in range(SIMD_TILE):
            vx_${N} = xnn_xor_f16(vx_${N}, vsign_flip_${N});
        $else:
          $for N in range(SIMD_TILE):
            xnn_simd_f16_t vy_${N} = xnn_mul_f16(vx_${N}, vtwo_over_pi);

          $for N in range(SIMD_TILE):
            xnn_simd_f16_t vk_${N} = xnn_add_f16(vy_${N}, vmagic);

          $for N in range(SIMD_TILE):
            xnn_simd_f16_t vk_float_${N} = xnn_sub_f16(vk_${N}, vmagic);

          $for N in range(SIMD_TILE):
            vx_${N} = xnn_fmadd_f16(vk_float_${N}, vhalf_pi_0, vx_${N});
          $for N in range(SIMD_TILE):
            vx_${N} = xnn_fmadd_f16(vk_float_${N}, vhalf_pi_1, vx_${N});

          $for N in range(SIMD_TILE):
            xnn_simd_f16_t vk_quad_${N} = xnn_add_f16(vk_${N}, vone);

          $for N in range(SIMD_TILE):
            xnn_simd_f16_t vmask_odd_${N} = xnn_sra_f16(xnn_sll_f16(vk_quad_${N}, 15), 15);
          $for N in range(SIMD_TILE):
            xnn_simd_f16_t vsign_flip_${N} = xnn_sll_f16(xnn_srl_f16(vk_quad_${N}, 1), 15);

          $for N in range(SIMD_TILE):
            xnn_simd_f16_t vabs_x_${N} = xnn_abs_f16(vx_${N});
          $for N in range(SIMD_TILE):
            xnn_simd_f16_t vsub_x_${N} = xnn_sub_f16(vpi_over_two, vabs_x_${N});
          $for N in range(SIMD_TILE):
            vx_${N} = xnn_or_f16(xnn_and_f16(vmask_odd_${N}, vsub_x_${N}), xnn_andnot_f16(vmask_odd_${N}, vx_${N}));
          $for N in range(SIMD_TILE):
            vx_${N} = xnn_xor_f16(vx_${N}, vsign_flip_${N});

        $for N in range(SIMD_TILE):
          const xnn_simd_f16_t vx2_${N} = xnn_mul_f16(vx_${N}, vx_${N});

        $for N in range(SIMD_TILE):
          xnn_simd_f16_t vp_${N} = xnn_fmadd_f16(vx2_${N}, vc3, vc2);
        $for N in range(SIMD_TILE):
          vp_${N} = xnn_fmadd_f16(vx2_${N}, vp_${N}, vc1);
        $for N in range(SIMD_TILE):
          vp_${N} = xnn_fmadd_f16(vx2_${N}, vp_${N}, vc0);

        $for N in range(SIMD_TILE):
          const xnn_simd_f16_t vy_res_${N} = xnn_mul_f16(vx_${N}, vp_${N});

        $for N in range(SIMD_TILE):
          xnn_storeu_f16(output + ${N} * xnn_simd_size_f16, vy_res_${N});
        output += ${BATCH_TILE};
      }

    for (; batch >= xnn_simd_bytes_f16; batch -= xnn_simd_bytes_f16) {
      xnn_simd_f16_t vx = xnn_loadu_f16(input);
      input += xnn_simd_size_f16;

      $if FUN == "SIN":
        xnn_simd_f16_t vy = xnn_mul_f16(vx, vone_over_pi);
        xnn_simd_f16_t vk = xnn_add_f16(vy, vmagic);
        xnn_simd_f16_t vk_float = xnn_sub_f16(vk, vmagic);

        vx = xnn_fmadd_f16(vk_float, vpi_0, vx);
        vx = xnn_fmadd_f16(vk_float, vpi_1, vx);

        xnn_simd_f16_t vsign_flip = xnn_sll_f16(vk, 15);
        vx = xnn_xor_f16(vx, vsign_flip);
      $else:
        xnn_simd_f16_t vy = xnn_mul_f16(vx, vtwo_over_pi);
        xnn_simd_f16_t vk = xnn_add_f16(vy, vmagic);
        xnn_simd_f16_t vk_float = xnn_sub_f16(vk, vmagic);

        vx = xnn_fmadd_f16(vk_float, vhalf_pi_0, vx);
        vx = xnn_fmadd_f16(vk_float, vhalf_pi_1, vx);

        xnn_simd_f16_t vk_quad = xnn_add_f16(vk, vone);

        xnn_simd_f16_t vmask_odd = xnn_sra_f16(xnn_sll_f16(vk_quad, 15), 15);
        xnn_simd_f16_t vsign_flip = xnn_sll_f16(xnn_srl_f16(vk_quad, 1), 15);

        xnn_simd_f16_t vabs_x = xnn_abs_f16(vx);
        xnn_simd_f16_t vsub_x = xnn_sub_f16(vpi_over_two, vabs_x);
        vx = xnn_or_f16(xnn_and_f16(vmask_odd, vsub_x), xnn_andnot_f16(vmask_odd, vx));
        vx = xnn_xor_f16(vx, vsign_flip);

      const xnn_simd_f16_t vx2 = xnn_mul_f16(vx, vx);
      xnn_simd_f16_t vp = xnn_fmadd_f16(vx2, vc3, vc2);
      vp = xnn_fmadd_f16(vx2, vp, vc1);
      vp = xnn_fmadd_f16(vx2, vp, vc0);

      const xnn_simd_f16_t vy_res = xnn_mul_f16(vx, vp);
      xnn_storeu_f16(output, vy_res);
      output += xnn_simd_size_f16;
    }

    if XNN_UNLIKELY(batch != 0) {
      xnn_simd_f16_t vx = xnn_load_tail_f16(input, batch >> XNN_LOG2_SIZEOF_FLOAT16);

      $if FUN == "SIN":
        xnn_simd_f16_t vy = xnn_mul_f16(vx, vone_over_pi);
        xnn_simd_f16_t vk = xnn_add_f16(vy, vmagic);
        xnn_simd_f16_t vk_float = xnn_sub_f16(vk, vmagic);

        vx = xnn_fmadd_f16(vk_float, vpi_0, vx);
        vx = xnn_fmadd_f16(vk_float, vpi_1, vx);

        xnn_simd_f16_t vsign_flip = xnn_sll_f16(vk, 15);
        vx = xnn_xor_f16(vx, vsign_flip);
      $else:
        xnn_simd_f16_t vy = xnn_mul_f16(vx, vtwo_over_pi);
        xnn_simd_f16_t vk = xnn_add_f16(vy, vmagic);
        xnn_simd_f16_t vk_float = xnn_sub_f16(vk, vmagic);

        vx = xnn_fmadd_f16(vk_float, vhalf_pi_0, vx);
        vx = xnn_fmadd_f16(vk_float, vhalf_pi_1, vx);

        xnn_simd_f16_t vk_quad = xnn_add_f16(vk, vone);

        xnn_simd_f16_t vmask_odd = xnn_sra_f16(xnn_sll_f16(vk_quad, 15), 15);
        xnn_simd_f16_t vsign_flip = xnn_sll_f16(xnn_srl_f16(vk_quad, 1), 15);

        xnn_simd_f16_t vabs_x = xnn_abs_f16(vx);
        xnn_simd_f16_t vsub_x = xnn_sub_f16(vpi_over_two, vabs_x);
        vx = xnn_or_f16(xnn_and_f16(vmask_odd, vsub_x), xnn_andnot_f16(vmask_odd, vx));
        vx = xnn_xor_f16(vx, vsign_flip);

      const xnn_simd_f16_t vx2 = xnn_mul_f16(vx, vx);
      xnn_simd_f16_t vp = xnn_fmadd_f16(vx2, vc3, vc2);
      vp = xnn_fmadd_f16(vx2, vp, vc1);
      vp = xnn_fmadd_f16(vx2, vp, vc0);

      const xnn_simd_f16_t vy_res = xnn_mul_f16(vx, vp);
      xnn_store_tail_f16(output, vy_res, batch >> XNN_LOG2_SIZEOF_FLOAT16);
    }
  }
